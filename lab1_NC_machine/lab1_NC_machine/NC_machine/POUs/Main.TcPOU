<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1">
  <POU Name="Main" Id="{ac33f91a-54de-4040-92d1-2ca91ce86f14}" SpecialFunc="None">
    <Declaration><![CDATA[PROGRAM Main
VAR
	xEnable: MC_Power;
	yEnable: MC_Power;
	zEnable: MC_Power;
	xReset : MC_Reset;			// Reset X
	yReset : MC_Reset;			// Reset Y
	zReset : MC_Reset;			// Reset Z
	
	xAxis: AXIS_REF;
	yAxis: AXIS_REF;
	zAxis: AXIS_REF;
	xPos: LREAL;
	yPos: LREAL;
	zPos: LREAL;
	
	Enable: BOOL;

	cGroup		: CfgBuild3DGroup;
	createGroup : BOOL;
	dGroup		: CfgReconfigGroup;
	deleteGroup : BOOL;
	loadProg    : ItpLoadProg;
	loadProgram : BOOL;
	progName    : STRING(255);
	lastProgName: STRING(255);
	resetChannel: ItpReset;
	reset   	: BOOL;
	startStop 	: ItpStartStop;
	start 		: BOOL;
	stop 		: BOOL;
	
	ncIn  AT %I* : NCTOPLC_NCICHANNEL_REF;
	ncOut AT %Q* : PLCTONC_NCICHANNEL_REF;
	
	//Manual mode
	xMove	: MC_MoveAbsolute;
	yMove	: MC_MoveAbsolute;
	zMove	: MC_MoveAbsolute;
	targetX : LREAL;
	targetY : LREAL;
	targetZ : LREAL;
	Manual  : BOOL;
	Auto    : BOOL;
	
	// Jog mode
	xJog 	: MC_Jog;
	yJog  	: MC_Jog;
	zJog	: MC_Jog;
	inching	: BOOL;
	xPlus	: BOOL;
	xMinus	: BOOL;
	yPlus	: BOOL;
	yMinus	: BOOL;
	zPlus	: BOOL;
	zMinus	: BOOL;
	moveToPos: BOOL;
	R_TRIG_0: R_TRIG;
	isNameChanged: BOOL;
	feedRate: LREAL := 100;
	ItpSingleBlock_0: ItpSingleBlock;
	triggerNext: BOOL;
	isSingleMode: BOOL;
	trigNext: R_TRIG;
	setMode : BOOL;
END_VAR
]]></Declaration>
